POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=postgres

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL_SECONDS=7200
JWT_REFRESH_TTL_SECONDS=2592000

BCRYPT_ROUNDS=12
AUTH_LOGIN_MAX_INFLIGHT=25
PG_POOL_MAX=30
PG_POOL_MIN=5
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECT_TIMEOUT_MS=5000

REDIS_URL=redis://localhost:6379
REDIS_CONNECT_MAX_RETRIES=10
REDIS_CONNECT_BASE_DELAY_MS=500
REDIS_OP_MAX_RETRIES=3
REDIS_OP_BASE_DELAY_MS=200
AI_GRADING_PREFIX_CACHE_REDIS_URL=redis://localhost:6379
AI_GRADING_PREFIX_CACHE_TTL_SECONDS=604800

MANUAL_GRADING_GET_SCOPE=TEACHER

AI_JOB_TIMEOUT_SECONDS=180
AI_JOB_MAX_ATTEMPTS=3
AI_JOB_RETRY_DELAY_SECONDS=5
AI_JOB_RETRY_MAX_DELAY_SECONDS=60
AI_JOB_PAYLOAD_TTL_SECONDS=86400
AI_JOB_STALE_SECONDS=300
AI_JOB_RECOVER_INTERVAL_SECONDS=60
AI_IMAGE_MAX_BYTES=9437184

AI_GRADING_PYTHON=python3

# api | auth | worker
SERVER_APP_PROFILE=api
RUN_MIGRATIONS=true
DISABLE_AI_WORKER=true

# Storage backend
# local | s3
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=uploads
LOCAL_STORAGE_PUBLIC_BASE=/uploads
STORAGE_SIGNED_URL_TTL_SECONDS=900
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=/s3
S3_REGION=us-east-1
S3_BUCKET=ai-homework-files
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_FORCE_PATH_STYLE=true

# Assistant service (server will call assistant_service/chat API)
ASSISTANT_BASE_URL=http://localhost:4100
ASSISTANT_HTTP_TIMEOUT_MS=15000
ASSISTANT_STREAM_CONNECT_TIMEOUT_MS=20000

ENABLE_METRICS=true
