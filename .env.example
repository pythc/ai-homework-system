POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=postgres

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL_SECONDS=7200
JWT_REFRESH_TTL_SECONDS=2592000
BCRYPT_ROUNDS=12
AUTH_LOGIN_MAX_INFLIGHT=25
PG_POOL_MAX=30
PG_POOL_MIN=5
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECT_TIMEOUT_MS=5000

# Redis
REDIS_URL=redis://redis:6379
AI_GRADING_PREFIX_CACHE_REDIS_URL=redis://redis:6379
AI_GRADING_PREFIX_CACHE_TTL_SECONDS=604800

# AI Grading
ARK_API_KEY=your_ark_api_key
ARK_MODEL=doubao-seed-2-0-mini-260215
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_GRADING_PYTHON=python3

# Server process profiles
# api | auth | worker
SERVER_APP_PROFILE=api
RUN_MIGRATIONS=true

# Storage backend
# local | s3
STORAGE_BACKEND=s3
LOCAL_STORAGE_ROOT=uploads
LOCAL_STORAGE_PUBLIC_BASE=/uploads
STORAGE_SIGNED_URL_TTL_SECONDS=900
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_BASE_URL=/s3
S3_REGION=us-east-1
S3_BUCKET=ai-homework-files
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Assistant Service
ASSISTANT_MODEL=doubao-seed-2-0-mini-260215
ASSISTANT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ASSISTANT_ENFORCE_ARK_API_KEY=
# Used for local run of assistant_service.
# Docker Compose deployment overrides it to http://web.
ASSISTANT_ASSET_BASE=https://110-lab.cn
ASSISTANT_SESSION_TTL_SECONDS=604800
ASSISTANT_MAX_OUTPUT_TOKENS=512

# Client build
VITE_API_BASE_URL=/api/v1
VITE_SCHOOL_NAME=重庆邮电大学
VITE_SCHOOLS=

# Caddy site hosts (docker compose, optional)
# Example: SITE_HOSTS=110-lab.cn, www.110-lab.cn
SITE_HOSTS=:80
